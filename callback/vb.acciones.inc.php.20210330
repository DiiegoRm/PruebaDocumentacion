		}
	$sql = "UPDATE `viabilidades` SET idestadovb=$VB_ST_APROBADA,notas=$obs,modify_user=$user->uid,`modify_date`=CURRENT_TIMESTAMP WHERE `id`=$id";
	if (db_query($sql,true) > 0){
		db_query("DELETE FROM bandejasvb WHERE idviabilidad=$id",true);
		db_query("INSERT INTO bandejasvb(idviabilidad, idgrupo) VALUES($id,$idbandeja)",true);
		db_query("INSERT INTO bandejasvb(idviabilidad, idgrupo) VALUES($id,$GRP_CONSTRUCCION_FO)",true);
        if ($idgrupoc==1||$idgrupoc==5||$idgrupoc==7||$idgrupoc==9||$idgrupoc==10||$idgrupoc==11||$idgrupoc==12){
            db_query("INSERT INTO bandejasvb(idviabilidad, idgrupo) VALUES($id,$idgrupoc)",true);
        }
		echo "OK";
	}
