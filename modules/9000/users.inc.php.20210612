						case 'new':
							$tipo=getStrVal($_POST['txtTipo_'.$idrow]);
							$idregion=getVal($_POST['txtCfg-Region_'.$idrow],"null");
							$idjefatura=getVal($_POST['txtCfg-Jefatura_'.$idrow],"null");
